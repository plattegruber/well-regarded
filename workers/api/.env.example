# Wrangler process config for `wrangler dev` in workers/api. Copy to `.env`
# (done for you by `pnpm run setup`); `.env` is gitignored.
#
# This file configures the wrangler CLI itself, NOT the worker runtime —
# runtime vars/secrets live in `.dev.vars`. Wrangler only reads Hyperdrive
# local connection strings from its process environment or this `.env` file;
# putting them in `.dev.vars` silently does nothing (verified on wrangler 4.110).

# Routes the HYPERDRIVE binding to the docker compose Postgres (local-only
# credentials; the canonical connection string). The suffix after `_STRING_`
# must exactly match the binding name in wrangler.jsonc (`HYPERDRIVE`) —
# a mismatch fails silently with a confusing connection error.
CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE=postgres://wellregarded:wellregarded@localhost:54322/wellregarded
