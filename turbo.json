{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": ["biome.json", "packages/tsconfig/*.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_*",
        "WRANGLER_HYPERDRIVE_LOCAL_CONNECTION_STRING_*",
        "CLOUDFLARE_ACCOUNT_ID",
        "CLOUDFLARE_API_TOKEN"
      ]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "lint": {},
    "typecheck": {}
  }
}
