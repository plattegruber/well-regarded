{
  "name": "@wellregarded/dashboard",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "pnpm run typegen && react-router dev",
    "deploy": "pnpm run build && wrangler deploy",
    "typegen": "wrangler types worker-configuration.d.ts --env-file=.env.example && react-router typegen",
    "test": "vitest run",
    "lint": "biome check .",
    "typecheck": "pnpm run typegen && tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@wellregarded/core": "workspace:*",
    "@wellregarded/db": "workspace:*",
    "@wellregarded/sources": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "isbot": "^5.1.31",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "7.18.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.44.0",
    "@react-router/dev": "7.18.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wellregarded/tsconfig": "workspace:*",
    "happy-dom": "^20.10.6",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vitest": "^3.2.4",
    "wrangler": "^4.110.0"
  }
}
