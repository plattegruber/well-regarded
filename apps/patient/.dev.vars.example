# Local env for `wrangler dev` in apps/patient. Copy to `.dev.vars` (done for
# you by `pnpm setup`); `.dev.vars` is gitignored and never committed.
# Keep in sync with `patientEnvSchema` in packages/core/src/env.ts and docs/secrets.md.

# Which environment this isolate believes it is in ("local" | "preview" | "prod").
ENVIRONMENT=local

# No Hyperdrive binding here: patient pages stay minimal-dependency by design,
# so this worker needs no local Postgres connection string.

# Patient link-token signing secret (issue #70): base64 of >= 32 random bytes.
# Generate a real value with `openssl rand -base64 32`. The value below is a
# deliberately non-random dev placeholder (base64 of an ASCII sentence) —
# never use it outside local dev. Optional until the apps/patient link routes
# land (TODO(#21) in packages/core/src/env.ts).
PATIENT_TOKEN_SECRET=d2VsbHJlZ2FyZGVkLWxvY2FsLWRldi1vbmx5LXBhdGllbnQtdG9rZW4tc2VjcmV0
