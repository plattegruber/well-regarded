{
  "extends": "@wellregarded/tsconfig/base.json",
  // Typecheck (`tsc --noEmit`) covers test files too — the drift guard in
  // src/contract/signalsTableDrift.test.ts and the R2Bucket assignability
  // check in src/rawArtifacts.test.ts are compile-time assertions and must
  // be part of the checked program. Build output is produced by
  // tsconfig.build.json, which excludes tests.
  "include": ["src"]
}
