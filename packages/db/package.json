{
  "name": "@wellregarded/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "seed": "pnpm --filter @wellregarded/db... build && node dist/seed/cli.js",
    "test": "vitest run --project unit",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@wellregarded/tsconfig": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@wellregarded/core": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  }
}
