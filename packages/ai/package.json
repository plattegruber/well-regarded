{
  "name": "@wellregarded/ai",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./safety": {
      "types": "./src/safety.ts",
      "import": "./dist/safety.js",
      "default": "./dist/safety.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.evals.json",
    "eval": "tsx evals/run.ts"
  },
  "devDependencies": {
    "@wellregarded/tsconfig": "workspace:*",
    "tsx": "^4.23.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@wellregarded/core": "workspace:*",
    "zod": "^4.4.3"
  }
}
