{
  "name": "well-regarded",
  "private": true,
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "dev": "turbo run dev",
    "dev:fake-gbp": "pnpm --filter @wellregarded/sources dev:fake-gbp",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "lint": "turbo run lint",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "eval": "pnpm --filter \"@wellregarded/ai^...\" build && pnpm --filter @wellregarded/ai eval",
    "gen:docs": "pnpm --filter @wellregarded/core gen:docs",
    "seed": "pnpm --filter @wellregarded/db seed",
    "db:generate": "pnpm --filter @wellregarded/db db:generate",
    "db:migrate": "pnpm --filter @wellregarded/db db:migrate",
    "db:studio": "pnpm --filter @wellregarded/db db:studio"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "turbo": "^2.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
